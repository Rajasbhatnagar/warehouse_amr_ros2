<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="amr_base" params="base_length base_width base_height wheel_radius wheel_width wheel_separation caster_offset_ratio caster_radius">
    <link name="base_link">
      <visual>
        <origin xyz="0 0 ${base_height/2.0}"/>
        <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${base_height/2.0}"/>
        <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${base_height/2.0}"/>
        <mass value="12.0"/>
        <inertia ixx="0.22" ixy="0.0" ixz="0.0" iyy="0.45" iyz="0.0" izz="0.60"/>
      </inertial>
    </link>

    <link name="left_wheel_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.6"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <link name="right_wheel_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.6"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="left_wheel_link"/>
      <origin xyz="0 ${wheel_separation/2.0} ${wheel_radius}"/>
      <axis xyz="0 1 0"/>
    </joint>

    <joint name="right_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="right_wheel_link"/>
      <origin xyz="0 -${wheel_separation/2.0} ${wheel_radius}"/>
      <axis xyz="0 1 0"/>
    </joint>

    <link name="caster_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="light_gray"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
      </inertial>
    </link>

    <joint name="caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="caster_link"/>
      <origin xyz="-${base_length/caster_offset_ratio} 0 ${caster_radius}"/>
    </joint>
  </xacro:macro>
</robot>
